<UserControl x:Class="SmartQB.UI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:SmartQB.UI.Views"
             xmlns:vm="clr-namespace:SmartQB.UI.ViewModels"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}"
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid Background="White" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Settings" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,20"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="600" HorizontalAlignment="Left">

                <TextBlock Text="AI Configuration" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,15"/>

                <TextBox Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="API Key"
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                         Margin="0,0,0,20" FontSize="14" />

                <TextBlock Text="Leave empty to use user-secrets or appsettings.json fallback."
                           FontSize="12" Foreground="Gray" Margin="0,-15,0,20"/>

                <TextBox Text="{Binding BaseUrl, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="Base URL (Optional)"
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                         Margin="0,0,0,20" FontSize="14" />

                <TextBlock Text="Example: https://api.deepseek.com/v1"
                           FontSize="12" Foreground="Gray" Margin="0,-15,0,20"/>

                <TextBox Text="{Binding ModelId, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="Model ID"
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                         Margin="0,0,0,30" FontSize="14" />

                <Button Content="Save Settings"
                        Command="{Binding SaveSettingsCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        HorizontalAlignment="Left" Width="150" Height="40" FontSize="16"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
