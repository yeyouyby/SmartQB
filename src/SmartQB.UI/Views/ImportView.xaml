<UserControl x:Class="SmartQB.UI.Views.ImportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:SmartQB.UI.Views"
             xmlns:vm="clr-namespace:SmartQB.UI.ViewModels"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:ImportViewModel, IsDesignTimeCreatable=True}"
             d:DesignHeight="600" d:DesignWidth="800">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Background="White">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MinWidth="500">
            <TextBlock Text="导入 PDF 试卷" Style="{StaticResource MaterialDesignHeadline4TextBlock}" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            <TextBlock Text="系统将自动分析排版、提取题目并使用 AI 进行逻辑解析与打标。"
                       Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                       Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Hint}"
                       HorizontalAlignment="Center" Margin="0,0,0,40" TextWrapping="Wrap" TextAlignment="Center"/>

            <Border BorderBrush="{DynamicResource PrimaryHueLightBrush}" BorderThickness="2" CornerRadius="12"
                    Width="500" Height="250" AllowDrop="True" Drop="Border_Drop" MouseLeftButtonDown="Border_MouseLeftButtonDown" Background="#FAFAFA"
                    Cursor="Hand">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F0F8FF" />
                                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryHueMidBrush}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <materialDesign:PackIcon Kind="FilePdfBox" Width="64" Height="64" Foreground="{DynamicResource PrimaryHueMidBrush}" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <TextBlock Text="请将 PDF 试卷拖拽至此处" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource MaterialDesignBody}"/>
                    <TextBlock Text="支持多页、图文混排的 PDF 文档" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="14" Foreground="Gray" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <TextBlock Text="{Binding StatusMessage}" Margin="0,30,0,0" HorizontalAlignment="Center" FontSize="16" FontWeight="Medium" Foreground="{DynamicResource PrimaryHueMidBrush}"/>

            <ProgressBar IsIndeterminate="True" Height="6" Width="500" Margin="0,20,0,0"
                         Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
                         Foreground="{DynamicResource PrimaryHueMidBrush}" Background="#E0E0E0"/>
        </StackPanel>
    </Grid>
</UserControl>
